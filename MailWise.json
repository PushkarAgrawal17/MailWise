    {
      "parameters": {
        "jsCode": "const now = new Date();\n\nconst start = new Date(now);\nstart.setDate(start.getDate() - 1);\nstart.setHours(0, 0, 0, 0);\n\nconst end = new Date(now);\nend.setDate(end.getDate() - 1);\nend.setHours(23, 59, 59, 999);\n\nconst todays = items.filter(item => {\n    const ts = new Date(item.json[\"Received At\"]);\n    return ts >= start && ts <= end;\n});\n\nconst emails = todays.map(email => `\nSubject: ${email.json.Subject}\n\nSender: ${email.json.Sender}\n\nSummary: ${email.json.Summary}\n\nLabels: ${email.json.Labels}\n\nReply Needed: ${email.json[\"Reply Needed\"]}\n\nHas Event: ${email.json[\"Has Event\"]}\n\nEvent Title: ${email.json[\"Event Title\"] || \"None\"}\n\nEvent Date: ${email.json[\"Event Date\"] || \"None\"}\n\n------------------------------------\n`).join(\"\\n\");\n\nconst stats = {\n    total: todays.length,\n    urgent: 0,\n    college: 0,\n    opportunities: 0,\n    bills: 0,\n    informational: 0,\n    spam: 0,\n    replies: 0,\n    events: 0\n};\n\nconst events = [];\nconst replyEmails = [];\nconst spamEmails = [];\n\ntodays.forEach(e => {\n\n    const labels = (e.json.Labels || \"\").split(\",\").map(x => x.trim());\n\n    if(labels.includes(\"Urgent\")) stats.urgent++;\n    if(labels.includes(\"College/TnP\")) stats.college++;\n    if(labels.includes(\"Opportunities\")) stats.opportunities++;\n    if(labels.includes(\"Bills & Subscriptions\")) stats.bills++;\n    if(labels.includes(\"Informational\")) stats.informational++;\n\n    if(e.json[\"Reply Needed\"] === true || e.json[\"Reply Needed\"] === \"true\")\n        stats.replies++;\n\n    if(e.json[\"Has Event\"] === true || e.json[\"Has Event\"] === \"true\")\n        stats.events++;\n\n    if (e.json[\"Has Event\"] === true || e.json[\"Has Event\"] === \"true\") {\n        events.push({\n            title: e.json[\"Event Title\"],\n            date: e.json[\"Event Date\"],\n            sender: e.json[\"Sender\"]\n        });\n    }\n\n    if (e.json[\"Reply Needed\"] === true || e.json[\"Reply Needed\"] === \"true\") {\n        replyEmails.push({\n            subject: e.json[\"Subject\"],\n            sender: e.json[\"Sender\"]\n        });\n    }\n\n    if (labels.includes(\"Spam\")) {\n        stats.spam++;\n    \n        spamEmails.push({\n            subject: e.json[\"Subject\"],\n            sender: e.json[\"Sender\"],\n            summary: e.json[\"Summary\"]\n        });\n    }\n});\n\nreturn [{\n    json: {\n        stats,\n        emails,\n        events,\n        replyEmails,\n        spamEmails\n    }\n}];"
      },
