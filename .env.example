# Groq
GROQ_API_KEY=your_groq_api_key

# Gmail OAuth (configured through n8n)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Google Calendar OAuth (configured through n8n)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Digest Email
DIGEST_EMAIL=[YOUR_EMAIL@gmail.com](mailto:YOUR_EMAIL@gmail.com)

# Timezone
TIMEZONE=Asia/Kolkata
